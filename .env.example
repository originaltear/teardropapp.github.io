# Copy this file to `.env` and fill in the real values.
# `.env` is gitignored and must never be committed.
#
# All EXPO_PUBLIC_* vars are inlined into the app binary at build time, so they
# are NOT secret from end users — they can be extracted from the APK. Keeping
# them here only prevents them from being committed to GitHub. Protect each key
# in its provider console (API key restrictions, package + SHA-1 allow-lists, RLS).

# ── Supabase ──────────────────────────────────────────────────────────────────
# Publishable/anon key — safe to ship in the client; access is enforced by RLS.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Maps (Android) ─────────────────────────────────────────────────────
# Restrict to the Maps SDK for Android + this app's package name & signing SHA-1.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── RevenueCat (Android) ──────────────────────────────────────────────────────
# test_... = Test Store (sandbox); use the live Play Store key for production.
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
