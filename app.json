{
  "expo": {
    "name": "Teardrop",
    "slug": "teardrop",
    "version": "1.0.0",
    "scheme": "teardrop",
    "orientation": "portrait",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070a14"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAx0n5iEvsWJxfLi7Va47uRXJwnNnEnctQ"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#0d1117",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "package": "com.originaltear.teardrop",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Teardrop uses your location to log where you cried.",
          "locationWhenInUsePermission": "Teardrop uses your location to log where you cried."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Teardrop accesses your photos to attach them to your cries.",
          "cameraPermission": "Teardrop uses your camera to take photos for your cries."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Teardrop uses your microphone to record voice notes for your cries."
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#0d1117",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6983c0e9-26de-4056-b0f5-5cef62d50bc3"
      }
    },
    "owner": "ishaq0000"
  }
}
