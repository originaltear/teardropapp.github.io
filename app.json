{
  "expo": {
    "name": "Teardrop",
    "slug": "teardrop",
    "version": "1.0.4",
    "scheme": "teardrop",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.originaltear.teardrop",
      "buildNumber": "12",
      "usesAppleSignIn": true,
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "versionCode": 10,
      "package": "com.originaltear.teardrop",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#070a14"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Teardrop uses your location to log where you cried.",
          "locationWhenInUsePermission": "Teardrop uses your location to log where you cried."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Teardrop accesses your photos to attach them to your cries.",
          "cameraPermission": "Teardrop uses your camera to take photos for your cries."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Teardrop uses your microphone to record voice notes for your cries.",
          "recordAudioAndroid": true,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#0d1117",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6983c0e9-26de-4056-b0f5-5cef62d50bc3"
      }
    },
    "owner": "ishaq0000"
  }
}
